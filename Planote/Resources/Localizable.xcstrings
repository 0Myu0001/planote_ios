    "撮影する準備ができましたか？" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Ready to capture?" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "촬영할 준비가 되셨나요?" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "准备好拍照了吗？" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "準備好拍照了嗎？" } }
      }
    },
    "下のボタンをタップして「カメラで撮影」を選択してください。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Tap the button below and choose \"Take Photo\"." } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "아래 버튼을 탭하고 \"카메라로 촬영\"을 선택하세요." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "点击下方按钮并选择「拍照」。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "點擊下方按鈕並選擇「拍照」。" } }
      }
    },
    "すでに写真やスクリーンショット、PDFがありますか？" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Already have a photo, screenshot, or PDF?" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "이미 사진, 스크린샷 또는 PDF가 있나요?" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "已有照片、截图或 PDF 了吗？" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "已有照片、截圖或 PDF 了嗎？" } }
      }
    },
    "下のボタンをタップして「写真を選択」もしくは「ファイルを選択」を選択して、予定が書かれている写真を選択してください。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Tap the button below and choose \"Choose Photo\" or \"Choose File\", then select an image with your schedule." } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "아래 버튼을 탭하고 \"사진 선택\" 또는 \"파일 선택\"을 선택한 후, 일정이 적힌 사진을 선택하세요." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "点击下方按钮,选择「选择照片」或「选择文件」,然后选择写有日程的图片。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "點擊下方按鈕,選擇「選擇照片」或「選擇檔案」,然後選擇寫有行程的圖片。" } }
      }
    },
